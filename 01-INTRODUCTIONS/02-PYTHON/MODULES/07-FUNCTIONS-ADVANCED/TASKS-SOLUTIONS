# ==================================================
# 3️⃣ *args — Solutions
# ==================================================

# Rank 1
def sum_numbers(*args):
    return sum(args)

print(sum_numbers(1, 2, 3))

# Rank 2
def max_value(*args):
    return max(args)

print(max_value(10, 20, 5))

# Rank 3
def print_all(*args):
    for value in args:
        print(value)

print_all("A", "B", "C")

# Rank 4
def average(*args):
    if len(args) == 0:
        return 0
    return sum(args) / len(args)

print(average(10, 20, 30))
print(average())

# Rank 5
def logger(*messages):
    for i, msg in enumerate(messages, start=1):
        print(f"{i}: {msg}")

logger("Start", "Processing", "Done")


# ==================================================
# 4️⃣ **kwargs — Solutions
# ==================================================

# Rank 1
def show_info(**kwargs):
    for k, v in kwargs.items():
        print(k, v)

show_info(name="Peyman", age=43)

# Rank 2
def build_user(**kwargs):
    return kwargs

print(build_user(name="Peyman", role="admin"))

# Rank 3
def settings(**kwargs):
    if kwargs.get("debug"):
        print("Debug mode ON")
    else:
        print("Debug mode OFF")

settings(debug=True)
settings()

# Rank 4
def validate_user(**kwargs):
    if "name" not in kwargs or "email" not in kwargs:
        raise ValueError("Missing required fields")
    return kwargs

try:
    print(validate_user(name="Peyman", email="p@mail.com"))
    print(validate_user(name="Peyman"))
except ValueError as e:
    print(e)

# Rank 5
def report(**kwargs):
    for k, v in kwargs.items():
        print(f"{k}: {v}")

report(cpu="80%", ram="16GB")


