# 7️⃣ Closures — Solutions
# ==================================================

# Rank 1
def outer_func():
    msg = "Hello"
    def inner():
        return msg
    return inner

f = outer_func()
print(f())

# Rank 2
def multiplier(n):
    def multiply(x):
        return x * n
    return multiply

double = multiplier(2)
print(double(5))

# Rank 3
def counter():
    count = 0
    def increment():
        nonlocal count
        count += 1
        return count
    return increment

c = counter()
print(c())
print(c())

# Rank 4
def role_checker(role):
    def check(user_role):
        return user_role == role
    return check

is_admin = role_checker("admin")
print(is_admin("admin"))

# Rank 5
def logger(prefix):
    def log(message):
        print(f"[{prefix}] {message}")
    return log

error_log = logger("ERROR")
error_log("File not found")


