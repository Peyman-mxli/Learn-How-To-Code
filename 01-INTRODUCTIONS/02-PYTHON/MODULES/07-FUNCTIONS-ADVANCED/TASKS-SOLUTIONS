# 6️⃣ Scope — Solutions
# ==================================================

# Rank 1
def local_scope():
    x = 10
    print(x)

local_scope()

# Rank 2
x = 50
def show_global():
    print(x)

show_global()

# Rank 3
counter = 0
def modify_global():
    global counter
    counter += 1

modify_global()
print(counter)

# Rank 4
def outer():
    y = 20
    def inner():
        print(y)
    inner()

outer()

# Rank 5
def outer_nonlocal():
    z = 0
    def inner():
        nonlocal z
        z += 1
        return z
    return inner

func = outer_nonlocal()
print(func())
print(func())


