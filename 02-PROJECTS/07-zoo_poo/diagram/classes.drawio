        <!-- Animal (abstract) -->
        <mxCell id="2" value="&lt;&lt;abstract&gt;&gt;\nAnimal" style="shape=swimlane;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="180" height="140" as="geometry"/>
        </mxCell>

        <!-- Mamifero -->
        <mxCell id="3" value="Mamifero" style="shape=swimlane;rounded=1;" vertex="1" parent="1">
