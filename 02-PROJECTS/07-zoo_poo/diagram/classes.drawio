<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Classes UML" id="classes">
    <mxGraphModel dx="1080" dy="720" grid="1" gridSize="10" guides="1">
      <root>
