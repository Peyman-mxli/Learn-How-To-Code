        </mxCell>

        <!-- Reptil -->
        <mxCell id="5" value="Reptil" style="shape=swimlane;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="300" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- Cuidador -->
        <mxCell id="6" value="Cuidador" style="shape=swimlane;rounded=1;" vertex="1" parent="1">
